# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Backlog Configuration
BACKLOG_HOST=
BACKLOG_API_KEY=
BACKLOG_PROJECT_KEY=

# Backlog Custom Field Names (Set these after running rearrange_backlog_v2.ts)
BACKLOG_FIELD_COUNTERPARTY=取引先名称
BACKLOG_FIELD_DEPT=依頼部署
BACKLOG_FIELD_DRAFT_URL=ドラフトURL
BACKLOG_FIELD_SIGN_METHOD=締結方法
BACKLOG_FIELD_TARGET_DATE=締結予定日
BACKLOG_FIELD_DEADLINE=希望納期
BACKLOG_FIELD_REMARKS=備考
BACKLOG_FIELD_DOC_NUMBER=文書番号

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=
# Phase 3 (LB-08): Matter案件フォルダのルート。未設定なら GOOGLE_DRIVE_FOLDER_ID を使用。
GOOGLE_DRIVE_MATTERS_ROOT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Self Company Configuration (Used for one-click autofill in documents)
COMPANY_NAME=サンプル株式会社
COMPANY_ADDRESS=東京都千代田区丸の内1-1-1
COMPANY_REPRESENTATIVE=代表取締役 山田 太郎
COMPANY_INVOICE_NO=T1234567890123

# PostgreSQL Configuration (Cloud SQL)
# Primary way to connect:
DATABASE_URL=postgres://user:password@host:5432/dbname

# Alternative: individual variables
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=
DB_PORT=5432
# For Cloud Run, use the connection name: PROJECT_ID:REGION:INSTANCE_ID
INSTANCE_CONNECTION_NAME=

# Contract Check API Configuration
LB_PORTAL_SECRET=

# -----------------------------------------------------------------------
# Admin UI (Vite) — bundle-time env vars
# -----------------------------------------------------------------------
# These are baked into the Admin UI bundle at `vite build`. Vite reads
# them via import.meta.env.VITE_*. The committed .env.production file
# already holds the production values; copy here only if you need to
# override for local dev or staging.
#
# When unset, the apiRouter passes /api/* fetches through unchanged
# (useful while running `npm run dev` against the legacy monolith).
VITE_API_READ_URL=
VITE_API_WRITE_URL=

# 法務ポータル: 条文解説ガイド(clause)等のDLバナーURL(portalRenderが置換)。
# Google スライド → PPTX エクスポートリンク等。本番は cloudbuild-api.yaml の
# --update-env-vars で Cloud Run に設定済み(ここはローカル/記録用)。
SERVICE_GUIDE_URL=https://docs.google.com/presentation/d/1n0PwoWQJYbsPdzzoC2DYfaLeL5hIFuvoq_PoI9q4kcE/export/pptx
LICENSE_GUIDE_URL=https://docs.google.com/presentation/d/1K0LB62rTYYXgKApMN1YwCgp_L9BRcgLoHDqRilaxhLc/export/pptx
GDRIVE_URL_SERVICE=https://docs.google.com/presentation/d/1n0PwoWQJYbsPdzzoC2DYfaLeL5hIFuvoq_PoI9q4kcE/export/pptx
GDRIVE_URL_LICENSE=https://docs.google.com/presentation/d/1K0LB62rTYYXgKApMN1YwCgp_L9BRcgLoHDqRilaxhLc/export/pptx

# 外部アドレス許可(アプリ側): staff 未登録でも通す明示メール許可リスト(カンマ区切り)。
# ※ アプリのロール審査用。IAP(GCP エッジ)のドメイン制限は別途 IAM での許可が必要。
LB_ROLE_ALLOWLIST_EMAILS=koktaa-s@kadokawa.jp
