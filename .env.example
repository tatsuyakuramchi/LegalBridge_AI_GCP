# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Backlog Configuration
BACKLOG_HOST=
BACKLOG_API_KEY=
BACKLOG_PROJECT_KEY=

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Self Company Configuration (Used for one-click autofill in documents)
COMPANY_NAME=サンプル株式会社
COMPANY_ADDRESS=東京都千代田区丸の内1-1-1
COMPANY_REPRESENTATIVE=代表取締役 山田 太郎
COMPANY_INVOICE_NO=T1234567890123

# PostgreSQL Configuration (Cloud SQL)
# Primary way to connect:
DATABASE_URL=postgres://user:password@host:5432/dbname

# Alternative: individual variables
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=
DB_PORT=5432
# For Cloud Run, use the connection name: PROJECT_ID:REGION:INSTANCE_ID
INSTANCE_CONNECTION_NAME=
